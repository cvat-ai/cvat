# Docker compose
# Your CVAT instance URL. Default is https://app.cvat.ai
CVAT_BASE_URL=https://app.cvat.ai
# Name of the function to create in CVAT.
FUNCTION_NAME=your_function_name
# Required to authenticate to CVAT API. You can get it in CVAT UI: https://app.cvat.ai/profile#security
CVAT_ACCESS_TOKEN=your_cvat_token
# Please specify your image url with tag. For example: myrepo/sam2:latest
IMAGE_URL=your_repo:your_image_tag
# SAM2 does not support multiple agents (yet?), so this value should be set to 1
AGENTS_COUNT=1
# Please specify your org slug if you want agent to deployed for organization
ORG_SLUG=""
# To use GPU, set this to "gpu". Requires Linux + NVIDIA GPU + NVIDIA driver + NVIDIA Container Toolkit + GPU docker image
COMPOSE_PROFILES=cpu
# Your Hugging Face token. Required if you want to exceed the rate limit for unauthenticated requests (https://huggingface.co/docs/hub/security-tokens#rate-limits-for-unauthenticated-requests).
HF_TOKEN=""

# To mount SAM2 model locally instead of downloading from Hugging Face every time:
#1. pip install huggingface_hub
#2. huggingface-cli download facebook/sam2.1-hiera-tiny
#3. Set USER_DATA_ABSOLUTE_PATH to your cache directory /Users/your_user_name/cache/huggingface/
#4. Set MODEL_CONFIG_PARAMS="-p model_id=str:facebook/sam2.1-hiera-tiny" (same as before, just make sure the model_id is correct)

USER_DATA_ABSOLUTE_PATH=""

#If you want to mount model from the cache
#COMPOSE_FILE=docker-compose.yaml:docker-compose-mount-cache.yaml

#note |custom model mounting is not yet supported for SAM2 yet,
#note |because SAM2VideoPredictor.from_pretrained() is used, it will be added.

# Model config params for SAM2
# Supported params are: model_id=str:model_id
# model_id - model_id from https://huggingface.co/models?search=facebook%2Fsam2
# MODEL_CONFIG_PARAMS="-p model_id=str:facebook/sam2.1-hiera-tiny"
MODEL_CONFIG_PARAMS="-p model_id=str:facebook/sam2.1-hiera-tiny"
