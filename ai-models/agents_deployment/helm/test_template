# Source: cvat-agent/templates/deployment.yaml
apiVersion: apps/v1
kind: Deployment
metadata:
  name: cvat-agent
  labels:
    app.kubernetes.io/name: cvat-agent
    app.kubernetes.io/instance: release-name
    app.kubernetes.io/version: "1.0.4"
    app.kubernetes.io/managed-by: Helm
spec:
  replicas: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: cvat-agent
      app.kubernetes.io/instance: release-name
  template:
    metadata:
      labels:
        app.kubernetes.io/name: cvat-agent
        app.kubernetes.io/instance: release-name
    spec:
      affinity:
        
        nodeAffinity:
          requiredDuringSchedulingIgnoredDuringExecution:
            nodeSelectorTerms:
            - matchExpressions:
              - key: nodetype
                operator: In
                values:
                - gpu
      nodeSelector:
        
        nodetype: gpu
      tolerations:
        
        - effect: NoSchedule
          key: key1
          operator: Equal
          value: value1
      securityContext:
        runAsNonRoot: true
        runAsUser: 1000
        runAsGroup: 1000
      containers:
        - name: cvat-agent
          securityContext:
            allowPrivilegeEscalation: false
          image: ":"
          imagePullPolicy: IfNotPresent
          #NB! configMap is created by job.yaml
          envFrom:
            - configMapRef:
                optional: true
                name: cvat-agent-config
          env:
            - name: CVAT_BASE_URL
              value: "https://app.cvat.ai"
            - name: CVAT_ACCESS_TOKEN
              valueFrom:
                secretKeyRef:
                  name: cvat-agent
                  key: token
            - name: NAMESPACE
              value: monitoring
            - name: CONFIGMAP_NAME
              value: cvat-agent-config
            - name: ORG_SLUG
              value: ""
            - name: MODEL_CONFIG_PARAMS
              value: "-p model=str:facebook/detr-resnet-50 -p task=str:object-detection"
            - name: USE_CUDA
              value: "false"
          resources:
            limits:
              cpu: 1
              nvidia.com/gpu: 1
            requests:
              cpu: 200m
              memory: 256Mi
              nvidia.com/gpu: 1
