# Docker compose
# Your CVAT instance URL. Default is https://app.cvat.ai
CVAT_BASE_URL=https://app.cvat.ai
# Name of the function to create in CVAT.
FUNCTION_NAME=your_function_name
# Required to authenticate to CVAT API. You can get it in CVAT UI: https://app.cvat.ai/profile#security
CVAT_ACCESS_TOKEN=your_cvat_token
# Please specify your image url with tag. For example: cvat/yolo_agent:latest
# NB! Right now we do not provide YOLO agent images. To get the image, please build it yourself using the Dockerfile in this directory.
IMAGE_URL=your_repo:your_image_tag
# Number of agents to deploy.
AGENTS_COUNT=1
# Please specify your org slug if you want agent to deployed for organization
ORG_SLUG=""
# To use GPU, set this to "gpu". Requires Linux + NVIDIA GPU + NVIDIA driver + NVIDIA Container Toolkit + GPU docker image
COMPOSE_PROFILES=cpu
# Your Hugging Face token. Required if you want to exceed the rate limit for unauthenticated requests (https://huggingface.co/docs/hub/security-tokens#rate-limits-for-unauthenticated-requests).
HF_TOKEN=""
# If you will set this to public, all users of your CVAT instance will be able to see and use the function.
# Otherwise only you and your organization members (if ORG_SLUG is set) will have access to it.
FUNCTION_VISIBILITY=private

# To mount YOLO model locally instead of downloading from Ultralytics servers:
# 1. Download the model: python -c "from ultralytics import YOLO; YOLO('yolo26s.pt')"
# 2. Set USER_DATA_ABSOLUTE_PATH to the directory containing the .pt file
# 3. Uncomment COMPOSE_FILE line below
# 4. Set MODEL_CONFIG_PARAMS="-p model=str:/app/data/yolo26s.pt"
# For custom-trained models, place your .pt file in the same directory and update the path accordingly.

USER_DATA_ABSOLUTE_PATH=""
#COMPOSE_FILE=docker-compose.yaml:docker-compose-mount-userdata.yaml

# Model config params for YOLO
# Supported params are: model=str:model_name, keypoint_names_path=str:path_to_file_with_keypoint_names
# model - model name from https://docs.ultralytics.com/models/yolo26/#supported-tasks-and-modes. Default is yolo26s.pt
# keypoint_names_path - path to a file with names of keypoints. Only valid for pose estimation models. By default, the 17 keypoint names from the COCO dataset (`nose`, `left_eye`, `right_eye`, etc.) will be used.
# MODEL_CONFIG_PARAMS="-p model=str:yolo26s-pose.pt -p keypoint_names_path=str:./keypoints.txt"

MODEL_CONFIG_PARAMS="-p model=str:yolo26s.pt"
