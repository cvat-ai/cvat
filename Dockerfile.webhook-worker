ARG CVAT_VERSION="dev"
FROM cvat/server:${CVAT_VERSION}

# pip was uninstalled from the base image for security reasons. Restore it just
# long enough to install psycopg3, then remove it again to keep the same posture.
USER root
RUN python -m ensurepip --upgrade \
    && python -m pip install --no-cache-dir "psycopg[binary,pool]" \
    && python -m pip uninstall -y pip
USER 1000:1000
