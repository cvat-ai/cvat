# Example environment for docker-compose.sso.yml.
# Copy to `.env.sso` and fill in real values.
# Usage:
#   docker compose --env-file .env.sso \
#     -f docker-compose.yml \
#     -f docker-compose.https.yml \
#     -f docker-compose.sso.yml up -d

# Public hostname users hit CVAT through (also used as Traefik Host rule
# and oauth2-proxy cookie domain).
CVAT_HOST=cvat.example.com

# --- Keycloak / OIDC -----------------------------------------------------

# Issuer URL of your Keycloak realm. The realm's
# `${SSO_OIDC_ISSUER_URL}/.well-known/openid-configuration` must be reachable
# from inside the oauth2-proxy container.
SSO_OIDC_ISSUER_URL=https://keycloak.example.com/realms/cvat

# Confidential client credentials configured in Keycloak. The client must
# have the redirect URI `https://${CVAT_HOST}/oauth2/callback` whitelisted
# under "Valid redirect URIs".
SSO_CLIENT_ID=cvat
SSO_CLIENT_SECRET=replace-with-keycloak-client-secret

# Cookie signing key for oauth2-proxy. Must be 16, 24 or 32 random bytes,
# base64 encoded. Generate with:
#   openssl rand -base64 32 | tr -d '\n'
SSO_COOKIE_SECRET=replace-with-32-byte-base64

# Where Keycloak should redirect the browser back to after sign-in. Must
# match the Valid Redirect URI configured in Keycloak.
SSO_REDIRECT_URL=https://cvat.example.com/oauth2/callback

# --- Optional ------------------------------------------------------------

# Restrict accepted users to one or more email domains. `*` allows all.
# Example: SSO_EMAIL_DOMAINS=example.com,partner.org
SSO_EMAIL_DOMAINS=*

# Set to `false` only if you serve CVAT over plain http (i.e. without
# docker-compose.https.yml). Production deployments should keep this true.
SSO_COOKIE_SECURE=true

# OIDC scopes requested from Keycloak. `groups` is added implicitly via
# OIDC_GROUPS_CLAIM below; tweak if your realm uses a custom scope name.
SSO_SCOPE=openid email profile

# Name of the claim Keycloak puts user groups / roles into. Defaults to
# `groups`; change if your realm uses something different (e.g. `roles`).
SSO_GROUPS_CLAIM=groups

# --- URL overrides (only when Keycloak's hostname is broken) ------------
# Set these only if your Keycloak's discovery document advertises a
# hostname that isn't reachable from inside the oauth2-proxy container
# (e.g. a dev Keycloak that returns `http://localhost:8081/...`).
# Leave blank to use whatever the discovery doc says.
#
# Example for a Keycloak running on the host at 192.168.x.y:8081:
#   SSO_LOGIN_URL=http://192.168.x.y:8081/realms/<realm>/protocol/openid-connect/auth
#   SSO_REDEEM_URL=http://192.168.x.y:8081/realms/<realm>/protocol/openid-connect/token
#   SSO_JWKS_URL=http://192.168.x.y:8081/realms/<realm>/protocol/openid-connect/certs
#   SSO_SKIP_ISSUER_VERIFICATION=true
SSO_LOGIN_URL=
SSO_REDEEM_URL=
SSO_JWKS_URL=
SSO_SKIP_ISSUER_VERIFICATION=false
# Set to `true` together with the four URL overrides above. For OIDC
# providers, oauth2-proxy otherwise re-reads URLs from the discovery
# document and ignores the overrides.
SSO_SKIP_OIDC_DISCOVERY=false

# Comma-separated claims oauth2-proxy uses to validate the token audience.
# Keycloak omits `aud` when the authorized party (`azp`) equals the client
# ID — set this to `azp` if you see "audience claims [aud] do not exist".
# Default: aud
SSO_AUDIENCE_CLAIMS=aud
